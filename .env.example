# Copy to .env (or inject into OpenClaw container environment).
# Never commit a real .env with secrets.

# --- Required ---
QAS_BASE_URL=http://<qas-host>:<qas-port>
QAS_TOKEN=<qas-token>
# Preferred in managed deployment: QAS_TOKEN_FILE=/run/secrets/openclaw_media_qas_token
PANSOU_BASE_URL=http://<pansou-host>:<pansou-port>
ARIA2_RPC_URL=http://<aria2-host>:<aria2-port>/jsonrpc
ARIA2_RPC_SECRET=<aria2-rpc-secret>
# Preferred in managed deployment: ARIA2_RPC_SECRET_FILE=/run/secrets/openclaw_media_aria2_rpc_secret
RESOURCE_AGENT_STATE_DB=/root/.openclaw/workspace/data/resource-download-agent/state.db

# --- Optional: PanSou ---
# Unique candidate cap (1-100). Default 50.
PANSOU_MAX_CANDIDATES=50

# --- Optional: Quark aria2 error-16 recovery (default off) ---
# When enabled, Agent may plan/execute Cookie re-push after user confirmation.
# downloads list/show never auto-recover.
QUARK_RECOVERY_ENABLED=false
QUARK_RECOVERY_MAX_ATTEMPTS=2
QUARK_RECOVERY_COOLDOWN_SECONDS=300

# --- Optional: 教父.com discovery (Playwright) ---
# Absolute path to Playwright storage state JSON after browser login.
# JIAOFU_STORAGE_STATE=/root/.openclaw/workspace/data/jiaofu_storage_state.json
# JIAOFU_MAX_CANDIDATES=20

# --- Optional: UGREEN Theater / 影视中心 local library API ---
# Used when filesystem catalog misses bilingual / scraped titles.
# auto = enable when token or reachable sock/url is available (default)
# 1 / 0 = force on / off
VIDEOMGR_ENABLED=auto
# Prefer HTTP from OpenClaw container to the NAS host gateway, e.g.:
# VIDEOMGR_BASE_URL=http://<nas-gateway-host>:9999
# Or unix sock when the container can see the host socket:
# VIDEOMGR_SOCK=/var/ugreen/video_serv.sock
# Session token (query param). Prefer Redis discovery on the NAS host:
# VIDEOMGR_TOKEN=
VIDEOMGR_REDIS_HOST=127.0.0.1
VIDEOMGR_REDIS_PORT=6379
# Prefer this UGOS username when multiple UGTOKEN-* sessions exist
# VIDEOMGR_PREFER_USER=<ugreen-username>
