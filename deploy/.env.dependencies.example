# Copy to .env before starting deploy/docker-compose.dependencies.yml
# Never commit the real .env file.

# Compose project timezone
TZ=Asia/Shanghai

# Shared Docker network name used by OpenClaw and dependencies
MEDIA_NETWORK=openclaw-media

# Host directories — replace with real NAS paths
QAS_CONFIG_DIR=/volume1/docker/openclaw-media/qas/config
PANSOU_CACHE_DIR=/volume1/docker/openclaw-media/pansou/cache
ARIA2_CONFIG_DIR=/volume1/docker/openclaw-media/aria2/config
DOWNLOADS_DIR=/volume2/downloads

# Local management ports — change when occupied
QAS_PORT=5005
PANSOU_PORT=8888
ARIA2_RPC_PORT=6800
ARIA2_WEB_PORT=6880

# Secrets — replace before deployment
ARIA2_RPC_SECRET=replace-with-a-long-random-secret

# Optional container user mapping; supported images may vary
PUID=1000
PGID=1000

# PanSou defaults
PANSOU_CHANNELS=tgsearchers3
PANSOU_ENABLED_PLUGINS=
