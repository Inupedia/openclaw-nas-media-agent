services:
  {{ service_name }}:
    networks:
      - openclaw_media
    volumes:
      - type: bind
        source: {{ downloads_host | yaml_quote }}
        target: /nas/downloads
      - type: bind
        source: {{ movie_host | yaml_quote }}
        target: /nas/library/movie
        read_only: true
      - type: bind
        source: {{ drama_host | yaml_quote }}
        target: /nas/library/drama
        read_only: true
      - type: bind
        source: {{ anime_host | yaml_quote }}
        target: /nas/library/anime
        read_only: true
      - type: bind
        source: {{ documentary_host | yaml_quote }}
        target: /nas/library/documentary
        read_only: true
      - type: bind
        source: {{ show_host | yaml_quote }}
        target: /nas/library/show
        read_only: true
      - type: bind
        source: {{ other_host | yaml_quote }}
        target: /nas/library/other
        read_only: true

networks:
  openclaw_media:
    external: true
    name: openclaw-media
